# Bỏ qua thư mục môi trường ảo
venv/
.venv/
env/

# Environment/secrets
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*.kdb
*.kdbx
*.secret
secrets.*
voices/

models/

# Bỏ qua thư mục thư viện của Node.js
node_modules/

# Python cache/build
__pycache__/
*.py[cod]

# Bỏ qua các file log lỗi (tùy chọn nhưng nên có)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Skip .wav and .glb file
*.wav
*.glb

# Ignore generated/public model asset folders
frontend/dist/models/
frontend/public/models/
