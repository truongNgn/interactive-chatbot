# LLM Provider: "ollama" | "deepseek"
LLM_PROVIDER=ollama

# Ollama configuration
# Local dev: http://localhost:11434
# Docker:    http://ollama:11434  (override tự động bởi docker-compose.yml)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:latest
OLLAMA_LARGE_MODEL=llama3.1:latest
OLLAMA_SMALL_MODEL=qwen2.5:1.5b
ROUTER_ENABLED=true

# DeepSeek configuration (dùng khi LLM_PROVIDER=deepseek)
# Lấy API key tại: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# ElevenLabs TTS (https://elevenlabs.io → Profile → API Keys)
ELEVENLABS_API_KEY=your_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# pcm_44100 = raw PCM 16-bit — được wrap thành WAV tự động, Rhubarb đọc được
# mp3_44100_128 = MP3 (không dùng được với Rhubarb nếu không có ffmpeg)
ELEVENLABS_OUTPUT_FORMAT=pcm_44100

# Rhubarb Lip Sync (Stage 4 — chính xác nhất, optional)
# Download: https://github.com/DanielSWolf/rhubarb-lip-sync/releases
# Windows: RHUBARB_PATH=./rhubarb/rhubarb.exe
# Để trống → fallback sang amplitude-based lip-sync (jawOpen theo RMS audio)
RHUBARB_PATH=

# Server configuration
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO

# Character Persona
CHARACTER_NAME=Aria
CHARACTER_BACKSTORY="I am a warm and empathetic AI companion."
CHARACTER_PERSONALITY="curious, caring, gently playful"

# LangSmith Observability (optional — xóa để tắt)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=interactive-chatbot
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com