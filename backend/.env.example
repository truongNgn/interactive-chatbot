# Ollama configuration
# In Docker: use service name "ollama" instead of localhost
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# ElevenLabs TTS (https://elevenlabs.io → Profile → API Keys)
ELEVENLABS_API_KEY=your_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Rhubarb Lip-Sync (Stage 4)
# Path to rhubarb binary. Leave empty to run without lip-sync.
# Local dev (Windows): RHUBARB_PATH=C:/tools/rhubarb.exe
# Docker: mount binary + set RHUBARB_PATH=/usr/local/bin/rhubarb
RHUBARB_PATH=

# Server configuration
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO
